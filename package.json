{
  "name": "@peter.naydenov/batch-runner",
  "description": "Execute a batch job with a simple call",
  "version": "2.4.1",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./dist/batch-runner.umd.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/batch-runner.esm.mjs",
      "require": "./dist/batch-runner.cjs",
      "default": "./dist/batch-runner.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "cover": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterNaydenov/batch-runner.git"
  },
  "devDependencies": {
    "@peter.naydenov/dom-selector": "^3.1.2",
    "@peter.naydenov/visual-controller-for-vue3": "^2.1.7",
    "@vitejs/plugin-vue": "^6.0.6",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  },
  "c8": {
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "node_modules",
      "test",
      "test-data"
    ],
    "reporter": [
      "lcov",
      "text-summary"
    ]
  },
  "keywords": [
    "batch",
    "job",
    "runner",
    "execute"
  ]
}
